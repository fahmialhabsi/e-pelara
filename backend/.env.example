# ============================================================
# e-PeLARA Backend — Environment Variables Template
# Salin file ini menjadi .env dan isi nilai yang sesuai.
# JANGAN commit file .env ke repository.
# ============================================================

# ---- Database (MySQL) ----
DB_NAME=db_epelara
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306

# ---- JWT ----
JWT_SECRET=ganti_dengan_secret_key_yang_kuat_dan_acak
JWT_REFRESH_SECRET=ganti_dengan_refresh_secret_key_yang_kuat_dan_acak
# JWT payload menyertakan tenant_id (multi-tenant). Data lama migrasi ke tenant id=1.

# ---- Redis ----
REDIS_URL=redis://localhost:6379
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY_MS=3000

# ---- SSO SIGAP (opsional — wajib jika integrasi SSO SIGAP aktif) ----
SSO_SHARED_SECRET=shared_secret_dari_sistem_sigap

# ---- Sinkron data kinerja / monev dari SIGAP ke lk_kinerja (CALK) ----
# GET JSON array { kode_referensi, judul, target, realisasi, satuan, kuartal? }
SIGAP_KINERJA_SYNC_URL=
SIGAP_KINERJA_SYNC_TOKEN=

# ---- Sinkron SPJ terverifikasi PPK (SIGAP-MALUT → BKU) ----
# Endpoint bridge di SIGAP: GET .../api/bridge/spj-approved?tahun=2024
# Samakan token dengan EPELARA_BRIDGE_TOKEN di backend SIGAP (opsional).
SIGAP_SPJ_SYNC_URL=http://localhost:5000/api/bridge/spj-approved
SIGAP_SYNC_TOKEN=

# URL logo OPD untuk halaman judul PDF LK (opsional)
LK_LOGO_URL=

# ---- OpenAI (opsional — rekomendasi AI di tab Preview indikator) ----
# Jika belum ada anggaran: REKOMENDASI_AI_ENABLED=false dan kosongkan OPENAI_API_KEY
# (rekomendasi diisi manual; tidak ada panggilan berbayar ke OpenAI).
REKOMENDASI_AI_ENABLED=false
# Satu baris, tanpa spasi di sekitar =. Restart backend setelah mengubah .env.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- CORS ----
# Daftar origin yang diizinkan, pisahkan dengan koma
CORS_ORIGINS=http://localhost:5173,http://localhost:3001,http://localhost:3013

# ---- App ----
NODE_ENV=development
PORT=3000

# ---- Sync RPJMD → RKPD (preview/commit; tidak overwrite data RKPD) ----
# Kosong atau tidak di-set = aktif. Set ke 0 untuk menonaktifkan endpoint (/api/rpjmd-rkpd-sync → 503).
# RPJMD_RKPD_SYNC_ENABLED=

# ---- Operational mode (SubKegiatan enforcement) ----
# Mode global default: LEGACY | TRANSITION | MASTER (disimpan di DB app_policy, lihat GET /api/v1/app-policy/operational-mode).
# Pilot tanpa ubah global — override khusus jalur sub_kegiatan + clone (prioritas di atas policy DB):
# EPELARA_OPERATIONAL_MODE_SUB_KEGIATAN=TRANSITION
# Cache baca policy (ms). 0 = nonaktif.
# EPELARA_POLICY_CACHE_MS=10000

# ---- Compliance histori + alert (opsional) ----
# Panduan lengkap: docs/regulasi/compliance-snapshot-operations.md
# Jadwalkan POST record (npm run job:compliance-record) tiap jam/hari agar GET ?trendHours= punya data.
# Webhook: dipanggil SETELAH record jika invalidMasterRowsMissingFk >= ambang (bukan pada GET).
# EPELARA_COMPLIANCE_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...
# EPELARA_COMPLIANCE_ALERT_WEBHOOK_SECRET=...
# EPELARA_COMPLIANCE_ALERT_MIN_INVALID_MASTER=1
#
# Job terjadwal (npm run job:compliance-record) — salah satu: JWT, file JWT, atau login admin.
# EPELARA_COMPLIANCE_RECORD_BASE_URL=http://127.0.0.1:3000
# EPELARA_COMPLIANCE_RECORD_JWT=...
# EPELARA_COMPLIANCE_RECORD_JWT_FILE=.secrets/compliance-record.jwt
# Atau akun khusus (SUPER_ADMIN / ADMINISTRATOR), tanpa paste JWT:
# EPELARA_COMPLIANCE_RECORD_LOGIN_EMAIL=job@localhost
# EPELARA_COMPLIANCE_RECORD_LOGIN_PASSWORD=...
